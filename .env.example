# Google Cloud Project 1 (Primary Route)
DISCOVERY_PROJECT_ID_1="your-project-id-1"
DISCOVERY_DATA_STORE_ID_1="your-data-store-id-1"
DISCOVERY_LOCATION_1="global"
DISCOVERY_COLLECTION_1="default_collection"

# OPTIONAL: Base64 Service Account Key
# If you don't provide this, the script will automatically fallback to Application Default Credentials (ADC)
# You can configure ADC locally by running: gcloud auth application-default login
GOOGLE_CLOUD_CREDENTIALS_BASE64_1="base64-encoded-service-account-key-1"

# Google Cloud Project 2 (Failover Route)
DISCOVERY_PROJECT_ID_2="your-project-id-2"
DISCOVERY_DATA_STORE_ID_2="your-data-store-id-2"
DISCOVERY_LOCATION_2="global"
DISCOVERY_COLLECTION_2="default_collection"
GOOGLE_CLOUD_CREDENTIALS_BASE64_2="base64-encoded-service-account-key-2"
